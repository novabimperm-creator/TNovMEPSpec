<Window x:Class="TNovMEPSpec.MEPSpecOVVKParamsWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovMEPSpec"
             mc:Ignorable="d" Width="400"
        d:DataContext="{d:DesignInstance local:MEPSpecOVVKParamsViewModel}"
            WindowStartupLocation="CenterScreen" 
            Background="White" BorderBrush="#FF008E43" BorderThickness="1"
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <!-- Стиль с полным шаблоном -->
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Убираем SystemColors -->
                        <ControlTemplate.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" 
                                         Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" 
                                         Color="Transparent"/>
                        </ControlTemplate.Resources>

                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- Прямое указание цвета -->
                                <Setter TargetName="border" 
                                    Property="Background" 
                                    Value="#FF008E43"/>
                                <!-- Цвет заголовка -->
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" 
                                    Property="Background" 
                                    Value="#FF008E43"/>
                                <!-- Темнее -->
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" 
                                    Property="Opacity" 
                                    Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
              ResizeBorderThickness="5"
              GlassFrameThickness="0"
              CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <!-- Верхняя панель (кастомный заголовок) -->
        <Border Height="30" 
                Background="#FF008E43" 
                VerticalAlignment="Top"
                MouseDown="Border_MouseDown">
            <TextBlock Text="Сводная спека" 
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
        </Border>

        <!-- Основное содержимое -->
        <Border Margin="0,30,0,0">

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Настройки заполнения параметров" Margin="0 5 0 5" TextAlignment="Center" TextWrapping="Wrap" TextDecorations="Underline" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding elemType}" Margin="0 5 0 5" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <GroupBox Header="Настройки заполнения Наименования" Padding="5">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="5">

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Параметр 1 (по типу)" Width="130" Margin="5" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding naimPar1}" Width="200" Margin="5" TextAlignment="Left" TextWrapping="Wrap" Height="25" BorderBrush="#CCCCCC"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Параметр 2" Width="80" Margin="5" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBox Text="{Binding naimPrefix2}" Width="60" Margin="5" TextAlignment="Left" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                                <ComboBox  VerticalAlignment="Top" Height="25" ItemsSource="{Binding paramlist}"
      SelectedItem="{Binding Path=naimPar2, Mode=TwoWay}"
      SelectedIndex = "0"
      MinWidth="180" Margin="5"
/>

                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Параметр 3" Width="80" Margin="5" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBox Text="{Binding naimPrefix3}" Width="60" Margin="5" TextAlignment="Left" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                                <ComboBox  VerticalAlignment="Top" Height="25" ItemsSource="{Binding paramlist}"
      SelectedItem="{Binding Path=naimPar3, Mode=TwoWay}"
      SelectedIndex = "0"
      MinWidth="180" Margin="5"
/>

                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Параметр 4" Width="80" Margin="5" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBox Text="{Binding naimPrefix4}" Width="60" Margin="5" TextAlignment="Left" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                                <ComboBox  VerticalAlignment="Top" Height="25" ItemsSource="{Binding paramlist}"
      SelectedItem="{Binding Path=naimPar4, Mode=TwoWay}"
      SelectedIndex = "0"
      MinWidth="180" Margin="5"
/>

                            </StackPanel>

                        </StackPanel>
                    </GroupBox>


                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <GroupBox Header="Настройки заполнения Количества" Padding="5">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="5">

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Исходный параметр" Width="150" Margin="5" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <ComboBox  VerticalAlignment="Top" Height="25" ItemsSource="{Binding paramlist2}"
      SelectedItem="{Binding Path=countPar, Mode=TwoWay}"
      SelectedIndex = "0"
      MinWidth="180" Margin="5"
/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Коэффициент" Width="90" Margin="5" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBox Text="{Binding countK}" Width="60" Margin="5" TextAlignment="Left" TextWrapping="Wrap" Height="25" BorderBrush="#CCCCCC"/>
                                <TextBlock Text="" Width="50" Margin="5" TextAlignment="Right" TextWrapping="Wrap" />
                            </StackPanel>


                        </StackPanel>
                    </GroupBox>


                </StackPanel>


                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Отмена" x:Name="escButton" IsCancel="True" Click="escButton_Click" Width="60" MinHeight="25" Margin="5" />
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Применить" x:Name="acceptButton" IsDefault="True" Click="acceptButton_Click" Width="120" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        </Border>
    </Grid>
    
    
</Window>
